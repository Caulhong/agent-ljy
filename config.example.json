{
  "agents": {
    "defaults": {
      "model": "deepseek/deepseek-chat",
      "stream": true,
      "temperature": 0.1,
      "maxTokens": 8192,
      "maxToolIterations": 40,
      "memoryWindow": 100
    }
  },
  "providers": {
    "deepseek": {
      "apiKey": "YOUR_DEEPSEEK_API_KEY",
      "apiBase": "https://api.deepseek.com/v1"
    }
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": true,
    "http": {
      "enabled": true,
      "host": "0.0.0.0",
      "port": 8000
    }
  }
}
